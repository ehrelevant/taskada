{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "XENDIT_SECRET_KEY",
    "EXPO_PUBLIC_API_URL",
    "PORT",
    "GOOGLE_MAPS_API_KEY",
    "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY",
    "AWS_REGION",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "S3_BUCKET_NAME",
    "S3_PUBLIC_URL",
    "XENDIT_CLIENT_SECRET",
    "XENDIT_API_URL",
    "VITE_API_URL",
    "CORS_ORIGINS",
    "LOG_LEVEL",
    "SEED_ADMIN_EMAIL",
    "SEED_ADMIN_PHONE",
    "SEED_ADMIN_PASSWORD"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dev"]
    }
  }
}
